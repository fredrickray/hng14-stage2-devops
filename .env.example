# Copy to ".env" and replace placeholders before running docker compose.
# Do not commit a real ".env" file.

# --- Docker Compose network ---
COMPOSE_NETWORK_NAME=jobstack_internal

# --- Redis (not published to the host; reachable only on the internal network) ---
REDIS_IMAGE=redis:7.2-alpine
REDIS_CONTAINER_NAME=jobstack-redis
REDIS_PASSWORD=__SET_A_STRONG_REDIS_PASSWORD__
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CPU_LIMIT=0.25
REDIS_MEMORY_LIMIT=256M
REDIS_HEALTHCHECK_INTERVAL=5s
REDIS_HEALTHCHECK_TIMEOUT=3s
REDIS_HEALTHCHECK_RETRIES=5
REDIS_HEALTHCHECK_START_PERIOD=5s

# --- Built service images (default prefix avoids Hub pulls named "api"/"worker"/"frontend"; CI overrides) ---
DOCKER_IMAGE_PREFIX=hng14-jobstack-
DOCKER_IMAGE_TAG=latest
API_CONTAINER_NAME=jobstack-api
WORKER_CONTAINER_NAME=jobstack-worker
FRONTEND_CONTAINER_NAME=jobstack-frontend

# --- API ---
API_CPU_LIMIT=0.50
API_MEMORY_LIMIT=512M
API_HEALTHCHECK_INTERVAL=10s
API_HEALTHCHECK_TIMEOUT=5s
API_HEALTHCHECK_RETRIES=5
API_HEALTHCHECK_START_PERIOD=20s

# --- Worker ---
WORKER_CPU_LIMIT=0.50
WORKER_MEMORY_LIMIT=512M
WORKER_HEALTHCHECK_INTERVAL=10s
WORKER_HEALTHCHECK_TIMEOUT=5s
WORKER_HEALTHCHECK_RETRIES=5
WORKER_HEALTHCHECK_START_PERIOD=20s

# --- Frontend (browser hits the published host/port; server calls API_URL) ---
FRONTEND_API_URL=http://api:8000
FRONTEND_BIND_ADDRESS=0.0.0.0
FRONTEND_INTERNAL_PORT=3000
FRONTEND_PUBLISH_HOST=127.0.0.1
FRONTEND_PUBLISH_PORT=3000
FRONTEND_CPU_LIMIT=0.50
FRONTEND_MEMORY_LIMIT=512M
FRONTEND_HEALTHCHECK_INTERVAL=10s
FRONTEND_HEALTHCHECK_TIMEOUT=5s
FRONTEND_HEALTHCHECK_RETRIES=5
FRONTEND_HEALTHCHECK_START_PERIOD=15s

# --- Integration test script (optional overrides) ---
# FRONTEND_TEST_HOST=127.0.0.1
